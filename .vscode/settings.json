{
  // ===========================================
  // COPILOT USER-LEVEL SETTINGS
  // ===========================================
  // Copy these into your VS Code User Settings (Ctrl+Shift+P -> "Open User Settings (JSON)")
  // on the Windows VM.
  //
  // Project-level settings go in each repo's .vscode/settings.json

  // ----- Copilot: Custom Instructions -----
  // All instructions live in per-project files (not inline settings):
  //   .github/copilot-instructions.md        -> global rules for the project
  //   .github/instructions/*.instructions.md  -> conditional per-filetype rules
  // The deprecated github.copilot.chat.*.instructions settings have been
  // removed in favor of instruction files. See README.md for details.

  // ----- Copilot: Enable CLAUDE.md support -----
  // This lets Copilot read existing CLAUDE.md files in repos
  "chat.useClaudeMdFile": true,

  // ----- Copilot: Instruction file locations -----
  "chat.instructionsFilesLocations": [
    { "directory": ".github/instructions" }
  ],

  // ----- Copilot: Agent Mode defaults -----
  "chat.agent.enabled": true,

  // ----- Copilot: Editor suggestions -----
  "github.copilot.enable": {
    "*": true,
    "plaintext": true,
    "markdown": true,
    "yaml": true
  },

  // ----- Next Edit Suggestions -----
  "github.copilot.nextEditSuggestions.enabled": true,

  // ----- Terminal integration -----
  "github.copilot.chat.terminalChatLocation": "terminal",

  // ----- Editor settings for consistency -----
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "explicit"
  },

  // ----- TypeScript -----
  "typescript.preferences.importModuleSpecifier": "non-relative",
  "typescript.suggest.autoImports": true,

  // ----- Git settings -----
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.postCommitCommand": "none",

  // ----- Files to exclude from Copilot context -----
  // Equivalent to .claudeignore
  "files.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/.next": true,
    "**/coverage": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/coverage": true,
    "**/package-lock.json": true,
    "**/yarn.lock": true,
    "**/pnpm-lock.yaml": true
  }
}
